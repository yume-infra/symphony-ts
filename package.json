{
  "name": "symphony-ts-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "Symphony TypeScript workspace",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "deps:check": "taze -r",
    "deps:check:all": "taze -r --all",
    "deps:fresh": "taze minor -r -w -i --maturity-period 7",
    "effect:source:update": "node scripts/effect-source-subtree.mjs update",
    "effect:source:verify": "node scripts/effect-source-subtree.mjs verify",
    "husky:install": "husky",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "pack:npm": "pnpm --filter @sayoriqwq/symphony-ts pack",
    "prepack": "pnpm build",
    "prepare": "node -e \"if (require('node:fs').existsSync('.git')) require('node:child_process').execFileSync('husky', { stdio: 'inherit', shell: true })\" && effect-tsgo patch",
    "publish:npm": "node scripts/publish-npm.mjs",
    "smoke:bin": "pnpm --filter @sayoriqwq/symphony-ts smoke:bin",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "typecheck:tsc": "turbo run typecheck:tsc",
    "verify": "pnpm effect:source:verify && pnpm build && pnpm typecheck && pnpm test && pnpm lint && pnpm knip"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@effect/tsgo": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "taze": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
