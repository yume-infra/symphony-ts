{
  "name": "symphony-ts",
  "type": "module",
  "version": "0.0.0",
  "description": "A CLI tool generated by create-yume",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "symphony-ts": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts && node scripts/ensure-shebang.mjs",
    "deps:check": "taze",
    "deps:check:all": "taze --all",
    "deps:fresh": "taze minor -w -i --maturity-period 7",
    "husky:install": "husky",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepack": "pnpm build",
    "prepare": "node -e \"if (require('node:fs').existsSync('.git')) require('node:child_process').execFileSync('husky', { stdio: 'inherit', shell: true })\"",
    "smoke:bin": "pnpm build && dist/index.js --help",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm knip"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "knip": "^6.12.0",
    "lint-staged": "^17.0.2",
    "taze": "^19.11.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
